# Public values are safe to expose in the browser. Never place service-role keys here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Legacy fallback is still supported by the app, but new Supabase projects should use
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only values for route handlers, Edge Functions, or backend APIs that use
# @supabase/server. Keep real secret keys only in .env.local or your hosting env.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=YOUR_SECRET_KEY_DO_NOT_COMMIT
SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json

# Server-only OpenAI settings for the AI listing draft route. Set real values in
# .env.local and in Vercel's Development, Preview, and Production environments.
OPENAI_API_KEY=
OPENAI_LISTING_MODEL=gpt-5-mini

# Prisma runtime: Supabase shared transaction-mode pooler (IPv4).
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PERCENT_ENCODED_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma CLI and migrations: Supabase shared session-mode pooler (IPv4).
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PERCENT_ENCODED_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres"
