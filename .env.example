# Public values are safe to expose in the browser. Never place service-role keys here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only: use only in trusted server routes/jobs, never in React components.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
